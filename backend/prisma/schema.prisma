generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  password      String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  lastLoginAt   DateTime?
  projects      Project[]
  refreshTokens RefreshToken[]

  personalAccessTokens PersonalAccessToken[]
  taskActivity         TaskActivity[]
  docAnnotations       DocAnnotation[]
}

// v1: full-access-as-the-user scope, no granular scopes yet. tokenHash is a
// fast SHA-256 digest (not bcrypt) -- PATs are 256 bits of randomness, not
// human-memorable secrets, so a fast deterministic hash is both sufficient
// and necessary here: it's what makes O(1) lookup-by-token possible on
// every authenticated request.
model PersonalAccessToken {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  label      String
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Project {
  id           String   @id @default(cuid())
  title        String
  description  String?
  shareToken   String   @unique @default(cuid())
  shareEnabled Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId      String
  groups       Group[]
  tasks        Task[]
  order        String[]

  // --- roadmap/kanban migration (expand phase) ---
  hasRoadmap   Boolean      @default(false)
  rolloverMode RolloverMode @default(ASK_FIRST)
  deletedAt    DateTime?
  statuses     Status[]
  roadmap      Roadmap?
  tags         Tag[]
  docEntries   DocEntry[]
  docCategories DocCategory[]
}

model Group {
  id        String    @id @default(cuid())
  title     String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  tasks     Task[]
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model Task {
  id          String           @id @default(cuid())
  title       String
  status      TaskStatusLegacy @default(TODO)
  priority    Priority         @default(NONE)
  comment     String?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  group       Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupId     String?

  // --- roadmap/kanban migration (expand phase) ---
  // statusId/position are nullable here so this phase stays purely additive;
  // both are backfilled and then made required in the contract phase, once
  // TaskStatusLegacy/status/Group/Project.order are dropped.
  updatedAt DateTime @updatedAt

  statusId   String?
  taskStatus Status? @relation("TaskCurrentStatus", fields: [statusId], references: [id])

  gateId String?
  gate   Gate?   @relation("TaskCurrentGate", fields: [gateId], references: [id])

  position Float?

  dueDate DateTime?

  blocked     Boolean @default(false)
  blockedNote String?

  // rollover provenance: where this task moved from, and when
  movedFromGateId String?
  movedFromGate   Gate?     @relation("TaskMovedFromGate", fields: [movedFromGateId], references: [id])
  movedFromGateAt DateTime?

  deletedAt DateTime?

  // lightweight commitment marker (not a Sprint entity)
  focus           Boolean   @default(false)
  focusTargetDate DateTime?

  // agent/external-sync provenance
  source     String  @default("manual")
  externalId String?
  sourceUrl  String?

  // Per-task public share link, lazily generated (nullable) the first time
  // sharing is enabled -- unlike Project.shareToken (eager, cuid default),
  // most tasks are never shared, so there's no reason to mint one for every
  // task on creation. Same lazy-generation approach as Gate.shareToken.
  shareToken   String?  @unique
  shareEnabled Boolean  @default(false)

  tags           TaskTag[]
  roadmaps       TaskRoadmap[]
  gatePlacements TaskGatePlacement[]
  syncProposals  SyncProposal[]
  activity       TaskActivity[]
  docLinks       TaskDocLink[]

  // NULL externalId rows are each distinct under Postgres unique-constraint
  // semantics, so this is only enforced when externalId is actually set --
  // exactly the "idempotent external syncs" behavior needed, no partial
  // index required.
  @@unique([source, externalId])
}

enum Role {
  USER
  ADMIN
}

enum TaskStatusLegacy {
  TODO
  DONE
}

enum Priority {
  NONE
  LOW
  MID
  HIGH
}

// --- roadmap/kanban migration (expand phase): new models ---

enum RolloverMode {
  AUTOMATIC
  ASK_FIRST
}

// Per-project Kanban columns. Exactly one row per project should have
// countsAsDone = true; Postgres has no clean native "exactly one true"
// constraint, so this is enforced in application logic, backed by a
// partial unique index (at most one countsAsDone per project) added by
// hand in the migration SQL since the Prisma schema DSL can't express a
// partial/filtered unique index directly.
model Status {
  id           String   @id @default(cuid())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  name         String
  order        Int
  countsAsDone Boolean  @default(false)
  createdAt    DateTime @default(now())

  tasks         Task[]         @relation("TaskCurrentStatus")
  syncProposals SyncProposal[]
}

// One roadmap per project for now (projectId is unique) -- just the FK,
// no multi-roadmap-per-project UI yet.
model Roadmap {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String   @unique
  createdAt DateTime @default(now())

  gates     Gate[]
  taskLinks TaskRoadmap[]
}

enum GateStatus {
  OPEN
  CLOSED
}

model Gate {
  id           String     @id @default(cuid())
  roadmap      Roadmap    @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  roadmapId    String
  name         String
  description  String?
  order        Int
  status       GateStatus @default(OPEN)
  closedAt     DateTime?
  closedReason String?
  createdAt    DateTime   @default(now())
  deletedAt    DateTime?

  // Lazily generated (nullable) the first time sharing is enabled for this
  // gate -- most gates are never shared individually.
  shareToken   String?  @unique
  shareEnabled Boolean  @default(false)

  tasksHere      Task[]              @relation("TaskCurrentGate")
  tasksMovedFrom Task[]              @relation("TaskMovedFromGate")
  roadmapLinks   TaskRoadmap[]
  gatePlacements TaskGatePlacement[]
}

model Tag {
  id        String    @id @default(cuid())
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  name      String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  tasks TaskTag[]

  @@unique([projectId, name])
}

model TaskTag {
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([taskId, tagId])
}

// A task can belong to additional roadmaps beyond its project's primary
// one, each with its own gateId within that other roadmap.
model TaskRoadmap {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  roadmap   Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  roadmapId String
  gateId    String?
  gate      Gate?    @relation(fields: [gateId], references: [id])
  createdAt DateTime @default(now())

  @@unique([taskId, roadmapId])
}

// Design choice for "a task placed in more than one gate of the SAME
// roadmap": one Task row (single source of truth for status, priority,
// comments, etc.) plus this join table for additional gate placements,
// rather than duplicate Task rows sharing a provenanceGroupId. Task.gateId
// remains the task's primary/canonical placement; rows here represent
// *additional* gates the same task is also visible in. Chosen over row
// duplication because duplicate rows would need explicit sync logic to
// keep title/status/priority/comments consistent across copies, which is
// exactly the kind of drift bug a single-row model avoids for free.
model TaskGatePlacement {
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  gate   Gate   @relation(fields: [gateId], references: [id], onDelete: Cascade)
  gateId String

  @@id([taskId, gateId])
}

enum SyncProposalStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

// v1 proposals are status moves only. Dismissed proposals are kept (not
// deleted) so agents can avoid re-proposing identical changes.
model SyncProposal {
  id               String             @id @default(cuid())
  task             Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId           String
  proposedStatus   Status             @relation(fields: [proposedStatusId], references: [id])
  proposedStatusId String
  reason           String
  source           String
  sourceUrl        String?
  status           SyncProposalStatus @default(PENDING)
  createdAt        DateTime           @default(now())
  decidedAt        DateTime?
}

enum TaskActivityEventType {
  status_changed
  gate_changed
  gate_assigned
  gate_removed
  focus_toggled
  due_date_set
  priority_changed
  blocked
  tag_added
  tag_removed
  comment_added
  moved_by_sync_proposal
  closed_gate_reason
  reopened_gate_reason
}

// Append-only audit log for a task's timeline -- no update endpoint, rows
// are only ever created by the mutation that caused them. oldValue/newValue
// are stored as display-ready text (status/gate names, not ids) so the
// timeline never needs a join at read time.
model TaskActivity {
  id        String                @id @default(cuid())
  task      Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  eventType TaskActivityEventType
  oldValue  String?
  newValue  String?
  changedAt DateTime              @default(now())
  changedBy User?                 @relation(fields: [changedById], references: [id], onDelete: SetNull)
  changedById String?
  reason    String?

  @@index([taskId, changedAt])
}

// --- Prompt 4: Docs ---

enum DocStatus {
  ACTIVE
  RETIRED
}

// Soft-deletable, same 30-day Trash pattern as Tag. Starter set (moat,
// decision, principle, reference, prd) is seeded per project on creation --
// renaming a category never touches DocEntry rows since category is an FK,
// not a text label copied onto each doc.
model DocCategory {
  id        String    @id @default(cuid())
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  name      String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  docs DocEntry[]

  @@unique([projectId, name])
}

// category is nullable -- "Uncategorized" is a real, valid state, not a
// placeholder category row.
model DocEntry {
  id         String       @id @default(cuid())
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  title      String
  category   DocCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId String?
  body       String
  status     DocStatus    @default(ACTIVE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  taskLinks   TaskDocLink[]
  annotations DocAnnotation[]
}

// Bidirectional task<->doc references. No status of its own -- a link
// either exists or doesn't. Soft-deleting a DocEntry severs (hard-deletes)
// its links rather than soft-deleting them; restoring the doc does not
// bring severed links back, matching "sever" rather than "hide."
model TaskDocLink {
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId     String
  docEntry   DocEntry @relation(fields: [docEntryId], references: [id], onDelete: Cascade)
  docEntryId String
  createdAt  DateTime @default(now())

  @@id([taskId, docEntryId])
}

// Flat, anchored margin notes -- no replies/resolution/threading at v1.
// anchor is a slugified heading id (e.g. "design-principles", or
// "design-principles-2" for a repeated heading) generated by the frontend's
// markdown renderer, shared verbatim between the table-of-contents links
// and the note's anchor so both always point at the same DOM id.
// authorId is stored now (single-author v1) so threaded replies can be
// added later without a schema change. Soft-deletable so a DocEntry's
// soft-delete can cascade to its annotations without losing history.
model DocAnnotation {
  id         String    @id @default(cuid())
  docEntry   DocEntry  @relation(fields: [docEntryId], references: [id], onDelete: Cascade)
  docEntryId String
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId   String
  anchor     String
  body       String
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  @@index([docEntryId])
}
