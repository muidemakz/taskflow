# Copy this file to .env.local for local development (preferred) or .env.
# .env.local is loaded automatically if present; .env is the fallback.
DATABASE_URL=postgresql://taskflow:taskflow@localhost:5432/taskflow
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=4000
FRONTEND_URL=http://localhost:5173

# Placeholders for the upcoming AI generation feature — not yet read by any code.
ENABLE_AI_GENERATION=false
ANTHROPIC_API_KEY=
